### RTU Emulator environment example
# Set this to your MongoDB Atlas connection string (include DB name)
# Example: mongodb+srv://user:pass@cluster0.mongodb.net/nqms?retryWrites=true&w=majority
MONGODB_URI=

# EMS (backend) base URL
EMS_URL=http://localhost:8080

# Use database for RTU/routes (true|false)
USE_DATABASE_RTU=true

# Monitoring interval (seconds)
MONITORING_INTERVAL=60

# Duplicate alarm suppression window in seconds
ALARM_DUPLICATE_SUPPRESSION_SECONDS=60
# RTU Configuration
RTU_ID=RTU_01
RTU_NAME=Remote Test Unit 01
RTU_LOCATION=Tunis Central Exchange

# EMS Connection
EMS_URL=http://ems-backend:8080
EMS_CONNECTION_TIMEOUT=10

# Monitoring Configuration
MONITORING_INTERVAL=300
AUTO_START=false

# OTDR test config (manual|auto)
OTDR_TEST_MODE=manual
OTDR_TEST_PERIOD_SECONDS=300

# Routes to Monitor (comma-separated)
ROUTES=OR_1,OR_2,OR_3,OR_4,OR_5

# Reference files root directory (contains route .json/.dat pairs)
ROUTES_REFERENCE_DIR=Routes

# Realistic power drift between tests (dB)
POWER_VARIATION_MIN_DB=0.1
POWER_VARIATION_MAX_DB=0.175

# Alarm Thresholds (in dB)
ALARM_THRESHOLD_DEGRADATION=3.0
ALARM_THRESHOLD_BREAK=10.0
EVENT_LOSS_THRESHOLD=1.0

# OTDR Simulation Parameters
FIBER_ATTENUATION=0.2
MIN_FIBER_LENGTH=10
MAX_FIBER_LENGTH=50
