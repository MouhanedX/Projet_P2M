### Frontend env example
# WebSocket endpoint used by SockJS/STOMP (use http:// or https://)
VITE_WS_URL=http://localhost:8080/ws
# API Configuration
# When running with Docker, use container name
VITE_API_URL=http://localhost:8080/api

# WebSocket Configuration
VITE_WS_URL=http://localhost:8080/ws
